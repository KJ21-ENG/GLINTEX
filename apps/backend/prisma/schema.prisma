generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Item {
  id    String @id @default(cuid())
  name  String
  lots  Lot[]
}

model Firm {
  id   String @id @default(cuid())
  name String
  lots Lot[]
}

model Supplier {
  id   String @id @default(cuid())
  name String
  lots Lot[]
}

model Lot {
  id          String     @id @default(cuid())
  lotNo       String     @unique
  date        String
  itemId      String
  firmId      String
  supplierId  String?
  totalPieces Int
  totalWeight Float
  createdAt   DateTime   @default(now())
  item        Item       @relation(fields: [itemId], references: [id])
  firm        Firm       @relation(fields: [firmId], references: [id])
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
}

model InboundItem {
  id        String  @id
  lotNo     String
  itemId    String
  weight    Float
  status    String
  seq       Int
  barcode   String  @unique
  createdAt DateTime @default(now())
}

model Machine {
  id                    String                  @id @default(cuid())
  name                  String
  issueToCutterMachines IssueToCutterMachine[]
}

model Operator {
  id                    String                              @id @default(cuid())
  name                  String
  role                  String                              @default("operator")
  issueToCutterMachines IssueToCutterMachine[]
  receiveRows           ReceiveFromCutterMachineRow[]      @relation("OperatorReceiveRows")
  helperRows            ReceiveFromCutterMachineRow[]      @relation("HelperReceiveRows")
}

model Bobbin {
  id          String                          @id @default(cuid())
  name        String
  weight      Float?                          // Weight in kg (BoxWt)
  receiveRows ReceiveFromCutterMachineRow[]
}

model IssueToCutterMachine {
  id          String  @id
  date        String
  itemId      String
  lotNo       String
  count       Int
  totalWeight Float
  pieceIds    String
  reason      String
  note        String?
  machineId   String?
  operatorId  String?
  barcode     String  @unique
  machine     Machine?  @relation(fields: [machineId], references: [id])
  operator    Operator? @relation(fields: [operatorId], references: [id])
}

model ReceiveFromCutterMachineUpload {
  id               String                              @id @default(cuid())
  originalFilename String
  uploadedAt       DateTime                            @default(now())
  rowCount         Int                                 @default(0)
  rows             ReceiveFromCutterMachineRow[]
}

model ReceiveFromCutterMachineRow {
  id            String                              @id @default(cuid())
  uploadId      String
  pieceId       String
  vchNo         String                              @unique
  narration     String?
  date          String?
  vchBook       String?
  barcode       String?
  shift         String?
  godownName    String?
  racNo         String?
  prodIssType   String?
  yarnName      String?
  itemName      String?
  cut           String?
  machineNo     String?
  employee      String?
  pktTypeName   String?
  pcsTypeName   String?
  bobbinId      String?
  boxId         String?
  operatorId    String?
  helperId      String?
  bobbinQuantity Int? @map("bobbin_quantity")
  grossWt       Float?
  tareWt        Float?
  netWt         Float?
  pktBoxWt      Float?
  pcsBoxWt      Float?
  yarnWt        Float?
  totalKg       Float?
  createdBy     String?
  modifiedBy    String?
  createdAt     DateTime                            @default(now())
  upload        ReceiveFromCutterMachineUpload      @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  bobbin        Bobbin?                              @relation(fields: [bobbinId], references: [id])
  box           Box?                                 @relation(fields: [boxId], references: [id])
  operator      Operator?                            @relation("OperatorReceiveRows", fields: [operatorId], references: [id])
  helper        Operator?                            @relation("HelperReceiveRows", fields: [helperId], references: [id])
}

model ReceiveFromCutterMachinePieceTotal {
  pieceId        String   @id
  totalNetWeight Float    @default(0)
  totalPieces    Int      @default(0)
  wastageNetWeight Float  @default(0)
  updatedAt      DateTime @updatedAt
}

model Settings {
  id           Int    @id @default(1)
  brandPrimary String
  brandGold    String
  logoDataUrl  String?
  whatsappNumber String?
  whatsappGroupIds String[] @default([])
}

model Sequence {
  id        String @id @default("lot_sequence")
  nextValue Int    @default(1)
}

model WhatsappTemplate {
  id       Int    @id @default(autoincrement())
  event    String @unique
  enabled  Boolean @default(true)
  template String
  sendToPrimary Boolean @default(true)
  groupIds String[] @default([])
}

model Box {
  id          String                          @id @default(cuid())
  name        String
  weight      Float
  receiveRows ReceiveFromCutterMachineRow[]
}


model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String?
  action     String
  payload    Json?
  payloadText String?
  createdAt  DateTime @default(now())
}
