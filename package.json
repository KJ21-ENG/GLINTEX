{
  "name": "glintex-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "dev:backend": "npm run dev --workspace apps/backend",
    "build:frontend": "npm run build --workspace apps/frontend",
    "build:backend": "npm run build --workspace apps/backend",
    "preview:frontend": "npm run preview --workspace apps/frontend",
    "start:backend": "npm run start --workspace apps/backend"
  },
  "dependencies": {
    "whatsapp-web.js": "github:pedroslopez/whatsapp-web.js#main"
  }
}
