generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Item {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  lots      Lot[]
}

model Yarn {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  issues    IssueToHoloMachine[]
}

model Cut {
  id           String   @id @default(cuid())
  name         String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  receiveRows  ReceiveFromCutterMachineRow[]
  cutterIssues IssueToCutterMachine[]
  holoIssues   IssueToHoloMachine[]
}

model Twist {
  id         String   @id @default(cuid())
  name       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  holoIssues IssueToHoloMachine[]
}

model Firm {
  id        String   @id @default(cuid())
  name      String
  address   String?
  mobile    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  lots      Lot[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  lots      Lot[]
}

model Lot {
  id          String     @id @default(cuid())
  lotNo       String     @unique
  date        String
  itemId      String
  firmId      String?
  supplierId  String?
  totalPieces Int
  totalWeight Float
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  item        Item       @relation(fields: [itemId], references: [id])
  firm        Firm?      @relation(fields: [firmId], references: [id])
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
}

model InboundItem {
  id              String   @id
  lotNo           String
  itemId          String
  weight          Float
  status          String
  seq             Int
  barcode         String   @unique
  consumptionDate String?
  isOpeningStock  Boolean  @default(false)
  dispatchedWeight Float   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model Machine {
  id                    String                  @id @default(cuid())
  name                  String
  processType           String                  @default("all")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now()) @updatedAt
  createdByUserId       String?
  updatedByUserId       String?
  issueToCutterMachines IssueToCutterMachine[]
  issueToHoloMachines   IssueToHoloMachine[]
  issueToConingMachines IssueToConingMachine[]
}

model Operator {
  id                    String                              @id @default(cuid())
  name                  String
  role                  String                              @default("operator")
  processType           String                              @default("all")
  createdAt             DateTime                            @default(now())
  updatedAt             DateTime                            @default(now()) @updatedAt
  createdByUserId       String?
  updatedByUserId       String?
  issueToCutterMachines IssueToCutterMachine[]
  receiveRows           ReceiveFromCutterMachineRow[]      @relation("OperatorReceiveRows")
  helperRows            ReceiveFromCutterMachineRow[]      @relation("HelperReceiveRows")
  holoIssues            IssueToHoloMachine[]                @relation("IssueToHoloOperator")
  coningIssues          IssueToConingMachine[]              @relation("IssueToConingOperator")
  holoReceiveRows       ReceiveFromHoloMachineRow[]        @relation("OperatorHoloReceive")
  holoHelperRows        ReceiveFromHoloMachineRow[]        @relation("HelperHoloReceive")
  coningReceiveRows     ReceiveFromConingMachineRow[]      @relation("OperatorConingReceive")
  coningHelperRows      ReceiveFromConingMachineRow[]      @relation("HelperConingReceive")
}

model Bobbin {
  id          String                          @id @default(cuid())
  name        String
  weight      Float?                          // Weight in kg (BoxWt)
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  receiveRows ReceiveFromCutterMachineRow[]
}

model IssueToHoloMachine {
  id                  String   @id @default(cuid())
  date                String
  itemId              String
  lotNo               String
  yarnId              String?
  twistId             String?
  machineId           String?
  operatorId          String?
  cutId               String?
  barcode             String   @unique
  note                String?
  shift               String?
  metallicBobbins     Int      @default(0)
  metallicBobbinsWeight Float  @default(0)
  yarnKg              Float    @default(0)
  receivedRowRefs     Json     @default("[]")
  rollsProducedEstimate Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
  createdByUserId     String?
  updatedByUserId     String?
  machine             Machine?  @relation(fields: [machineId], references: [id])
  operator            Operator? @relation("IssueToHoloOperator", fields: [operatorId], references: [id])
  yarn                Yarn?      @relation(fields: [yarnId], references: [id])
  twist               Twist?     @relation(fields: [twistId], references: [id])
  cut                 Cut?       @relation(fields: [cutId], references: [id])
  receiveRows         ReceiveFromHoloMachineRow[] @relation("IssueHoloRelation")
}

model ReceiveFromHoloMachineRow {
  id          String   @id @default(cuid())
  date        String?
  issueId     String
  rollCount   Int
  rollWeight  Float?
  rollTypeId  String?
  grossWeight Float?
  tareWeight  Float?
  barcode     String?  @unique
  boxId       String?
  machineNo   String?
  operatorId  String?
  helperId    String?
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  dispatchedWeight Float   @default(0)
  issue       IssueToHoloMachine @relation("IssueHoloRelation", fields: [issueId], references: [id])
  rollType    RollType?          @relation(fields: [rollTypeId], references: [id])
  box         Box?               @relation(fields: [boxId], references: [id])
  operator    Operator?           @relation("OperatorHoloReceive", fields: [operatorId], references: [id])
  helper      Operator?           @relation("HelperHoloReceive", fields: [helperId], references: [id])
}

model ReceiveFromHoloMachinePieceTotal {
  pieceId         String   @id
  totalRolls      Int      @default(0)
  totalNetWeight  Float    @default(0)
  wastageNetWeight Float   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model RollType {
  id        String   @id @default(cuid())
  name      String   @unique
  weight    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  receiveRows ReceiveFromHoloMachineRow[]
}

model ConeType {
  id        String   @id @default(cuid())
  name      String   @unique
  weight    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model Wrapper {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model StickerTemplate {
  id         String   @id @default(cuid())
  stageKey   String   @unique
  dimensions Json
  content    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model IssueToConingMachine {
  id              String   @id @default(cuid())
  date            String
  itemId          String
  lotNo           String
  machineId       String?
  operatorId      String?
  barcode         String   @unique
  note            String?
  shift           String?
  rollsIssued     Int      @default(0)
  requiredPerConeNetWeight Float   @default(0)
  expectedCones  Float     @default(0)
  receivedRowRefs Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  machine         Machine?  @relation(fields: [machineId], references: [id])
  operator        Operator? @relation("IssueToConingOperator", fields: [operatorId], references: [id])
  receiveRows     ReceiveFromConingMachineRow[] @relation("IssueConingRelation")
}

model ReceiveFromConingMachineRow {
  id          String   @id @default(cuid())
  barcode     String?  @unique
  date        String?
  issueId     String
  coneCount   Int
  coneWeight  Float?
  netWeight   Float?
  tareWeight  Float?
  grossWeight Float?
  boxId       String?
  machineNo   String?
  operatorId  String?
  helperId    String?
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  issue       IssueToConingMachine @relation("IssueConingRelation", fields: [issueId], references: [id])
  operator    Operator?            @relation("OperatorConingReceive", fields: [operatorId], references: [id])
  helper      Operator?            @relation("HelperConingReceive", fields: [helperId], references: [id])
  box         Box?                 @relation(fields: [boxId], references: [id])
  dispatchedWeight Float            @default(0)
}

model ReceiveFromConingMachinePieceTotal {
  pieceId         String   @id
  totalCones      Int      @default(0)
  totalNetWeight  Float    @default(0)
  wastageNetWeight Float   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model IssueToCutterMachine {
  id          String  @id
  date        String
  itemId      String
  lotNo       String
  cutId       String?
  count       Int
  totalWeight Float
  pieceIds    String
  reason      String
  note        String?
  machineId   String?
  operatorId  String?
  barcode     String  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  cut         Cut?      @relation(fields: [cutId], references: [id])
  machine     Machine?  @relation(fields: [machineId], references: [id])
  operator    Operator? @relation(fields: [operatorId], references: [id])
}

model ReceiveFromCutterMachineUpload {
  id               String                              @id @default(cuid())
  originalFilename String
  uploadedAt       DateTime                            @default(now())
  createdAt        DateTime                            @default(now())
  updatedAt        DateTime                            @default(now()) @updatedAt
  createdByUserId  String?
  updatedByUserId  String?
  rowCount         Int                                 @default(0)
  rows             ReceiveFromCutterMachineRow[]
}

model ReceiveFromCutterMachineRow {
  id            String                              @id @default(cuid())
  uploadId      String
  pieceId       String
  vchNo         String                              @unique
  narration     String?
  date          String?
  vchBook       String?
  barcode       String?
  shift         String?
  godownName    String?
  racNo         String?
  prodIssType   String?
  yarnName      String?
  itemName      String?
  cut           String?
  machineNo     String?
  employee      String?
  pktTypeName   String?
  pcsTypeName   String?
  bobbinId      String?
  boxId         String?
  operatorId    String?
  helperId      String?
  helperName    String?
  bobbinQuantity Int? @map("bobbin_quantity")
  issuedBobbins  Int   @default(0)
  issuedBobbinWeight Float @default(0)
  grossWt       Float?
  tareWt        Float?
  netWt         Float?
  pktBoxWt      Float?
  pcsBoxWt      Float?
  yarnWt        Float?
  totalKg       Float?
  createdBy     String?
  modifiedBy    String?
  challanId     String?
  isDeleted     Boolean                            @default(false)
  deletedAt     DateTime?
  deletedByUserId String?
  createdAt     DateTime                            @default(now())
  updatedAt     DateTime                            @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  upload        ReceiveFromCutterMachineUpload      @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  challan       ReceiveFromCutterMachineChallan?    @relation(fields: [challanId], references: [id])
  bobbin        Bobbin?                              @relation(fields: [bobbinId], references: [id])
  box           Box?                                 @relation(fields: [boxId], references: [id])
  operator      Operator?                            @relation("OperatorReceiveRows", fields: [operatorId], references: [id])
  helper        Operator?                            @relation("HelperReceiveRows", fields: [helperId], references: [id])
  cutId         String?
  cutMaster     Cut?                                 @relation(fields: [cutId], references: [id])
  dispatchedWeight Float                             @default(0)
}

model ReceiveFromCutterMachineChallan {
  id              String   @id @default(cuid())
  challanNo       String   @unique
  sequence        Int
  fiscalYear      String
  pieceId         String
  lotNo           String
  itemId          String?
  date            String?
  totalNetWeight  Float    @default(0)
  totalBobbinQty  Int      @default(0)
  operatorId      String?
  helperId        String?
  cutId           String?
  wastageNetWeight Float   @default(0)
  wastageNote     String?
  changeLog       Json     @default("[]")
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  deletedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  rows            ReceiveFromCutterMachineRow[]
}

model ReceiveFromCutterMachinePieceTotal {
  pieceId        String   @id
  totalNetWeight Float    @default(0)
  totalBob       Int      @default(0)
  wastageNetWeight Float  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model Settings {
  id           Int    @id @default(1)
  brandPrimary String
  brandGold    String
  logoDataUrl  String?
  faviconDataUrl String?
  whatsappNumber String?
  whatsappGroupIds String[] @default([])
  backupTime   String @default("03:00")
  challanFromName    String?
  challanFromAddress String?
  challanFromMobile  String?
  challanFieldsConfig Json   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model GoogleDriveCredential {
  id           Int      @id @default(1)
  refreshToken String
  accessToken  String?
  tokenExpiry  DateTime?
  email        String?
  folderId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Sequence {
  id        String @id @default("lot_sequence")
  nextValue Int    @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model HoloIssueSequence {
  id        String @id @default("holo_issue_seq")
  nextValue Int    @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model ConingIssueSequence {
  id        String @id @default("coning_issue_seq")
  nextValue Int    @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model WhatsappTemplate {
  id       Int    @id @default(autoincrement())
  event    String @unique
  enabled  Boolean @default(true)
  template String
  sendToPrimary Boolean @default(true)
  groupIds String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
}

model Box {
  id          String                          @id @default(cuid())
  name        String
  weight      Float
  processType String                          @default("all")
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  receiveRows ReceiveFromCutterMachineRow[]
  holoReceiveRows ReceiveFromHoloMachineRow[]
  coningReceiveRows ReceiveFromConingMachineRow[]
}


model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String?
  action     String
  actorUserId String?
  actorUsername String?
  actorRoleKey String?
  payload    Json?
  payloadText String?
  createdAt  DateTime @default(now())
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  users       User[]
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String?
  passwordHash String
  roleId       String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  role         Role     @relation(fields: [roleId], references: [id])
  sessions     UserSession[]
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  ip         String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ========== DISPATCH FEATURE ==========

model Customer {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  dispatches  Dispatch[]
}

model DispatchSequence {
  id        String   @id // Format: "dispatch_seq_2025_26"
  nextValue Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Dispatch {
  id              String   @id @default(cuid())
  challanNo       String   @unique // Format: DC/2025-26/001
  date            String
  customerId      String
  stage           String   // "inbound" | "cutter" | "holo" | "coning"
  stageItemId     String   // ID of the source item
  stageBarcode    String   // Original barcode of the dispatched item
  weight          Float
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  createdByUserId String?
  updatedByUserId String?
  customer        Customer @relation(fields: [customerId], references: [id])
}

// ========== BOX TRANSFER FEATURE ==========

model BoxTransfer {
  id                String        @id @default(cuid())
  date              String
  stage             String        // "holo" | "coning" | "cutter"
  fromBarcode       String
  fromItemId        String        // ID of source receive row
  toBarcode         String
  toItemId          String        // ID of destination receive row
  pieceCount        Int           // Number of pieces transferred
  weightTransferred Float         // Net weight transferred
  notes             String?
  isReversed        Boolean       @default(false)
  reversedById      String?       @unique
  reversedBy        BoxTransfer?  @relation("ReverseTransfer", fields: [reversedById], references: [id])
  reversesTransfer  BoxTransfer?  @relation("ReverseTransfer")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
  createdByUserId   String?
  updatedByUserId   String?
}
