DATABASE_URL="postgresql://postgres:password@localhost:5432/glintex_dev"
PORT=4000
GOOGLE_DRIVE_CLIENT_ID="your-google-client-id"
GOOGLE_DRIVE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_DRIVE_REDIRECT_URI="http://localhost:4001/api/google-drive/callback"

# Use this for local (npm) runs so they target your host Postgres on 5432.
# The docker-compose stack exposes its own Postgres on host 5433; leave this
# unchanged to keep the two environments separate and runnable at the same time.
