generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id    String @id @default(cuid())
  name  String
  lots  Lot[]
}

model Firm {
  id   String @id @default(cuid())
  name String
  lots Lot[]
}

model Supplier {
  id   String @id @default(cuid())
  name String
  lots Lot[]
}

model Lot {
  id          String     @id @default(cuid())
  lotNo       String     @unique
  date        String
  itemId      String
  firmId      String
  supplierId  String?
  totalPieces Int
  totalWeight Float
  createdAt   DateTime   @default(now())
  item        Item       @relation(fields: [itemId], references: [id])
  firm        Firm       @relation(fields: [firmId], references: [id])
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
}

model InboundItem {
  id        String  @id
  lotNo     String
  itemId    String
  weight    Float
  status    String
  seq       Int
  createdAt DateTime @default(now())
}

model Machine {
  id               String           @id @default(cuid())
  name             String
  issueToMachines  IssueToMachine[]
}

model Operator {
  id               String           @id @default(cuid())
  name             String
  issueToMachines  IssueToMachine[]
}

model IssueToMachine {
  id          String  @id
  date        String
  itemId      String
  lotNo       String
  count       Int
  totalWeight Float
  pieceIds    String
  reason      String
  note        String?
  machineId   String?
  operatorId  String?
  machine     Machine?  @relation(fields: [machineId], references: [id])
  operator    Operator? @relation(fields: [operatorId], references: [id])
}

model Settings {
  id           Int    @id @default(1)
  brandPrimary String
  brandGold    String
  logoDataUrl  String?
  whatsappNumber String?
}

model Sequence {
  id        String @id @default("lot_sequence")
  nextValue Int    @default(1)
}

model WhatsappTemplate {
  id       Int    @id @default(autoincrement())
  event    String @unique
  enabled  Boolean @default(true)
  template String
}


