FROM node:20-bullseye AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_BASE=
ENV VITE_API_BASE=${VITE_API_BASE}
ARG VITE_FF_V2_STOCK=
ARG VITE_FF_V2_ISSUE_TRACKING=
ARG VITE_FF_V2_RECEIVE_HISTORY=
ARG VITE_FF_V2_OPENING_STOCK=
ARG VITE_FF_V2_ON_MACHINE=
ENV VITE_FF_V2_STOCK=${VITE_FF_V2_STOCK}
ENV VITE_FF_V2_ISSUE_TRACKING=${VITE_FF_V2_ISSUE_TRACKING}
ENV VITE_FF_V2_RECEIVE_HISTORY=${VITE_FF_V2_RECEIVE_HISTORY}
ENV VITE_FF_V2_OPENING_STOCK=${VITE_FF_V2_OPENING_STOCK}
ENV VITE_FF_V2_ON_MACHINE=${VITE_FF_V2_ON_MACHINE}
ENV ROLLUP_SKIP_NODE_NATIVE=1
RUN npm run build

FROM nginx:1.27-alpine AS runner
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
